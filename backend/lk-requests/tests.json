{
  "tests": [
    {
      "name": "Unauthorized list",
      "method": "POST",
      "path": "/",
      "body": {"action": "list"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Upload file without auth",
      "method": "POST",
      "path": "/",
      "body": {"action": "upload_file", "file_b64": "dGVzdA==", "filename": "test.pdf", "file_type": "INVOICE"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown_xyz"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    }
  ]
}
