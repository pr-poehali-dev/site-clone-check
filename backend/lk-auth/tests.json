{
  "tests": [
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_lk_client@example.com", "password": "wrongpass_xyz"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный email или пароль"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login client",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_lk_client@example.com", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Unknown action"},
      "bodyMatcher": "partial"
    }
  ]
}